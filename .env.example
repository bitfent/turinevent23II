PORT=8080
NODE_ENV=development

# Postgres connection string (Supabase, Render Postgres, etc.)
DATABASE_URL=postgresql://user:password@host:5432/database

# Absolute base URL for the deployed site, with scheme and no trailing slash.
# Used for Open Graph / WhatsApp link previews and canonical URLs.
# Example: https://thenewmoney.youhodler.com
# Leave unset locally — the server will fall back to the request host.
PUBLIC_BASE_URL=
