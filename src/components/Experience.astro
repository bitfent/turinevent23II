---
---
<section id="experience" class="section experience" aria-labelledby="experience-title">
  <div class="experience__background" aria-hidden="true">
    <img src="/stadio-torino.jpg" alt="" loading="lazy" decoding="async" />
    <div class="experience__background-overlay"></div>
  </div>

  <div class="container experience__inner">
    <header class="section__head reveal">
      <p class="eyebrow eyebrow--accent">Matchday experience</p>
      <h2 id="experience-title">When the program ends, the day continues</h2>
      <p class="section__lede section__lede--light">
        Every confirmed participant will receive a complimentary ticket for Torino vs Juventus, taking place the same evening at Stadio Olimpico Grande Torino.
      </p>
      <p class="section__lede section__lede--light section__lede--muted">
        A limited number of VIP guests will be hosted in the skybox. Additional guests will receive selected grandstand seats.
      </p>
      <p class="section__lede section__lede--light section__lede--muted">
        Because the best business conversations often continue outside the meeting room.
      </p>
    </header>

    <ul class="experience__perks reveal">
      <li>
        <span class="experience__perk-label">Ticket</span>
        <strong>Complimentary derby seat</strong>
        <p>For every confirmed participant.</p>
      </li>
      <li>
        <span class="experience__perk-label">VIP</span>
        <strong>Skybox hospitality</strong>
        <p>Selected guests · limited availability.</p>
      </li>
      <li>
        <span class="experience__perk-label">Networking</span>
        <strong>Senior peers in one room</strong>
        <p>Curated business audience, no public crowd.</p>
      </li>
    </ul>

    <p class="experience__sponsor reveal">
      <span class="sponsor-badge sponsor-badge--inverse">
        <span class="sponsor-badge__crest" aria-hidden="true">
          <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 3l11 4v8c0 7-5 12-11 14-6-2-11-7-11-14V7l11-4z"/>
            <path d="M11 14h10"/><path d="M11 18h10"/>
          </svg>
        </span>
        <span class="sponsor-badge__text">
          <strong>YouHodler</strong>
          <em>Official Sponsor of Torino&nbsp;FC</em>
        </span>
      </span>
    </p>
  </div>
</section>
