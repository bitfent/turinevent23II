---
---
<section class="hero" aria-labelledby="hero-title">
  <div class="hero__background" aria-hidden="true">
    <img src="/stadio-torino.jpg" alt="" loading="eager" decoding="async" />
    <div class="hero__background-overlay"></div>
  </div>

  <div class="container hero__inner">
    <div class="hero__copy">
      <p class="eyebrow reveal">
        <span class="eyebrow__dot" aria-hidden="true"></span>
        Invitation-only business event · Turin · Sunday, 24 May 2026
      </p>
      <h1 id="hero-title" class="hero__title reveal">
        The <span class="text-gradient">New&nbsp;Money</span>
      </h1>
      <p class="hero__subtitle reveal">
        What digital assets can do for your business today.
      </p>
      <p class="hero__text reveal">
        A private afternoon for CEOs, CFOs, founders and decision makers to explore how digital assets can support real business needs:
        international payments, liquidity management, multi-currency operations and faster financial flows.
      </p>
      <p class="hero__text hero__text--muted reveal">
        Hosted by YouHodler at the Press Room of Stadio Olimpico Grande Torino,
        the event brings together business insight, selected networking and an exclusive matchday experience around Torino vs Juventus.
      </p>

      <div class="hero__ctas reveal">
        <a class="btn btn--primary btn--lg" href="#apply">Request an invitation</a>
        <a class="btn btn--ghost btn--lg" href="#program">View the program</a>
      </div>

      <ul class="hero__chips reveal" aria-label="Event highlights">
        <li><span class="dot"></span>B2B only</li>
        <li><span class="dot"></span>Limited seats</li>
        <li><span class="dot"></span>Approval required</li>
        <li><span class="dot"></span>Derby ticket included</li>
      </ul>

      <p class="hero__sponsor reveal" aria-label="Sponsorship">
        <span class="sponsor-badge">
          <span class="sponsor-badge__crest" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 3l11 4v8c0 7-5 12-11 14-6-2-11-7-11-14V7l11-4z"/>
              <path d="M11 14h10"/><path d="M11 18h10"/>
            </svg>
          </span>
          <span class="sponsor-badge__text">
            <strong>YouHodler</strong>
            <em>Official Sponsor of Torino&nbsp;FC</em>
          </span>
        </span>
      </p>
    </div>

    <aside class="hero__card reveal" aria-label="Event details">
      <span class="hero__card-glow" aria-hidden="true"></span>
      <p class="hero__card-label">Event details</p>
      <h2 class="hero__card-title">Sunday, 24 May 2026</h2>
      <p class="hero__card-venue">
        Press Room<br />
        Stadio Olimpico Grande&nbsp;Torino<br />
        <span class="hero__card-address">Via Filadelfia 191, Turin</span>
      </p>

      <ul class="hero__schedule" aria-label="Schedule preview">
        <li><time>TBD</time><span>Check-in</span></li>
        <li><time>TBD</time><span>Keynote</span></li>
        <li><time>TBD</time><span>Aperitivo &amp; networking</span></li>
        <li class="hero__schedule-accent"><time>TBD</time><span>Torino vs Juventus</span></li>
      </ul>

      <a class="hero__card-cta" href="#apply">
        Apply to attend
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14"/><polyline points="13 6 19 12 13 18"/>
        </svg>
      </a>
    </aside>
  </div>
</section>
