<section id="program" class="section section--alt" aria-labelledby="program-title">
  <div class="container">
    <header class="section__head reveal">
      <p class="eyebrow eyebrow--accent">Program</p>
      <h2 id="program-title">A focused afternoon before the derby</h2>
      <p class="section__lede">
        A compact agenda. Senior peers in the room. Then the day continues at Stadio Olimpico Grande Torino.
      </p>
    </header>

    <ol class="timeline reveal" aria-label="Event schedule">
      <li class="timeline__item">
        <time class="timeline__time">TBD</time>
        <div class="timeline__body">
          <h3>Check-in &amp; welcome</h3>
          <p>Arrival at the Press Room of Stadio Olimpico Grande Torino.</p>
        </div>
      </li>
      <li class="timeline__item">
        <time class="timeline__time">TBD</time>
        <div class="timeline__body">
          <h3>Keynote</h3>
          <p>Where digital assets stand for businesses in 2026.</p>
        </div>
      </li>
      <li class="timeline__item">
        <time class="timeline__time">15:50</time>
        <div class="timeline__body">
          <h3>Business solutions</h3>
          <p>Practical tools YouHodler makes available to companies.</p>
        </div>
      </li>
      <li class="timeline__item">
        <time class="timeline__time">TBD</time>
        <div class="timeline__body">
          <h3>Aperitivo &amp; networking</h3>
          <p>Selected networking with business leaders and the YouHodler team.</p>
        </div>
      </li>
      <li class="timeline__item timeline__item--accent">
        <time class="timeline__time">TBD</time>
        <div class="timeline__body">
          <h3>Torino vs Juventus</h3>
          <p>Complimentary match ticket for confirmed participants.</p>
        </div>
      </li>
    </ol>
  </div>
</section>
